    ‚àá Create_pipelines(device window);default_format;depth_format;v_shader;f_shader;vb_desc;vb_attr;blend_state;ct_desc
      (v_shader f_shader)‚Üê(v_ub:1 ‚ãÑ f_ub:1 ‚ãÑ f_sp:1)##.Create_shaders device'basic_vert' 'basic_frag'
      default_format‚Üê‚äÉ##.SDL_GetGPUSwapchainTextureFormat device window
      depth_format‚Üê##.Get_depth_format device
     ‚çù Load shaders
     
      _‚Üê##.LSE_PipelineClearParams ‚ç¨
      _‚Üê##.LSE_PipelineSetShaders v_shader f_shader
    ‚çù Vertex Buffer Descriptions and Attributes : Vertex Input
      vb_desc‚Üê‚äÇ(0 4 0 0)
      vb_attr‚Üê‚äÇ(0 0 ##.SDL_GPU_VERTEXELEMENTFORMAT_UBYTE4 0)
     
      _‚Üê##.LSE_PipelineSetVertexInput vb_desc 1 vb_attr 1
      _‚Üê##.LSE_PipelineSetDepthStencil 2 0 0 1 1 0
      _‚Üê##.LSE_PipelineSetRasterizer 0 2 1 0 0 0 0 0
     
    ‚çù Color Targets
      blend_state‚Üê(##.SDL_GPU_BLENDFACTOR_SRC_ALPHA
          ##.SDL_GPU_BLENDFACTOR_ONE_MINUS_SRC_ALPHA
          ##.SDL_GPU_BLENDOP_ADD)
    ‚çù 0's - padding, writemask, etc
    ‚çù Duplicate alpha and color blendfactors and blendops
      blend_state‚Üê(6‚ç¥blend_state),5‚ç¥0
      ct_desc‚Üê‚äÇdefault_format blend_state
     
      _‚Üê##.LSE_PipelineSetTargetInfo ct_desc 1 depth_format 1
