:Namespace state
    ‚éïIO‚Üê0


    ‚çù State Machine Enumeration based off of "My Favorite Verbose Programming Technique"
    ‚çù https://github.com/Co-dfns/APL-Asteroids
    ‚çù Was previously doing namespace swapping for state handling
    ‚çù -- Want to see if there is any perceivable benefit of doing this instead.


    ‚çù Overall pattern:
    ‚çù - Each state has a mini-event loop that is exhausted before
    ‚çù   being updated and drawn, hence %_EVENT_ precedes %_.
    ‚çù   This is an equivalent of "while polling check if input" but
    ‚çù   'unrolled.'
    ‚çù
    ‚çù - A helper operator that checks if user is quitting or if window is
    ‚çù   resized is added to make this process a bit easier.
    ‚çù
    ‚çù - Menu and Saves share the same resources but are different
    ‚çù   enough in logic to be conceptually split up, hence they go to
    ‚çù   the same release function.


    (TICK QUIT BACK NEXT) ‚Üê 1+‚ç≥4

    ‚àá Game_loop core
     
      ##.menu_state.Init core
     
     ‚çù ----------
     ‚çù Menu State
     ‚çù ----------
     
     ‚àÜ_MENU_EVENT_:‚Üí‚éïLC+##.menu_state.Input _Exhaust_with core
     ‚àÜ_MENU_EVENT_TICK:‚Üí‚àÜ_MENU_EVENT_
     ‚àÜ_MENU_EVENT_QUIT:‚Üí‚àÜ_MENU_QUIT
     ‚àÜ_MENU_EVENT_BACK:‚àò‚àò‚àò
     ‚àÜ_MENU_EVENT_NEXT:‚Üí‚àÜ_MENU_
     
     ‚àÜ_MENU_:‚Üí‚éïLC+##.menu_state.Loop_menu core
     ‚àÜ_MENU_TICK:‚Üí‚àÜ_MENU_EVENT_
     ‚àÜ_MENU_QUIT:##.menu_state.Release core ‚ãÑ ‚Üí0
     ‚àÜ_MENU_BACK:‚àò‚àò‚àò
     ‚àÜ_MENU_NEXT:‚Üí‚àÜ_SAVES_EVENT_
     
     ‚çù -----------
     ‚çù Saves State
     ‚çù -----------
     
     ‚àÜ_SAVES_EVENT_:‚Üí‚éïLC+##.menu_state.Input _Exhaust_with core
     ‚àÜ_SAVES_EVENT_TICK:‚Üí‚àÜ_SAVES_EVENT_
     ‚àÜ_SAVES_EVENT_QUIT:‚Üí‚àÜ_MENU_QUIT
     ‚àÜ_SAVES_EVENT_BACK:‚àò‚àò‚àò
     ‚àÜ_SAVES_EVENT_NEXT:‚Üí‚àÜ_SAVES_
     
     ‚àÜ_SAVES_:‚Üí‚éïLC+##.menu_state.Loop_saves core
     ‚àÜ_SAVES_TICK:‚Üí‚àÜ_SAVES_EVENT_
     ‚àÜ_SAVES_QUIT:‚Üí‚àÜ_MENU_QUIT
     ‚àÜ_SAVES_BACK:‚Üí‚àÜ_MENU_
     ‚àÜ_SAVES_NEXT:Saves_to_world core ‚ãÑ ‚Üí‚àÜ_WORLD_EVENT_
     
     ‚çù -----------
     ‚çù World State
     ‚çù -----------
     
     ‚àÜ_WORLD_EVENT_:‚Üí‚éïLC+##.world_state.Input _Exhaust_with core
     ‚àÜ_WORLD_EVENT_TICK:‚Üí‚àÜ_WORLD_EVENT_
     ‚àÜ_WORLD_EVENT_QUIT:‚Üí‚àÜ_WORLD_QUIT
     ‚àÜ_WORLD_EVENT_BACK:‚àò‚àò‚àò
     ‚àÜ_WORLD_EVENT_NEXT:‚Üí‚àÜ_WORLD_
     
     ‚àÜ_WORLD_:‚Üí‚éïLC+##.world_state.Loop core
     ‚àÜ_WORLD_TICK:‚Üí‚àÜ_WORLD_EVENT_
     ‚àÜ_WORLD_QUIT:##.world_state.Release core ‚ãÑ ‚Üí0
     ‚àÜ_WORLD_BACK:‚àò‚àò‚àò
     ‚àÜ_WORLD_NEXT:‚àò‚àò‚àò
    ‚àá

    ‚àá Saves_to_world core;save
      save‚Üê##.menu_state.next_world
      ##.menu_state.Release core
      ##.world_state.Init core save
    ‚àá

    ‚àá a‚Üê(Exhaust_fn _Exhaust_with)core
      a‚ÜêTICK
      :If 0=‚äÉ##.LSE_PollEvent
          a‚ÜêNEXT
          :Return
      :EndIf
      :If ##.LSE_CheckEvent ##.SDL_EVENT_QUIT
          a‚ÜêQUIT
      :ElseIf ##.LSE_CheckEvent ##.SDL_EVENT_KEY_DOWN
          :If ##.SDLK_Q=‚äÉ##.LSE_GetKeyPressed ‚ç¨
              a‚ÜêQUIT
          :EndIf
      :ElseIf ##.LSE_CheckEvent ##.SDL_EVENT_WINDOW_RESIZED
          (core.w core.h)‚Üê##.LSE_GetWindowResize 0 0
      :EndIf
      
      Exhaust_fn core
    ‚àá

    ‚àá Play
      res‚Üê##.SDL_Init ##.SDL_INIT_VIDEO
      'Error initializing SDL3'##.Assert res
     
      window‚Üê##.SDL_CreateWindow'A Voxel Game' 1280 720 32
      'Error creating window'##.Assert window
     
      device‚Üê##.SDL_CreateGPUDevice(
          ##.Get_shader_format ‚ç¨
          1
          ##.Get_device_backend ‚ç¨
      )
      'Error creating GPU device'##.Assert device
      res‚Üê##.SDL_ClaimWindowForGPUDevice device window
      'Error attaching GPU device to window'##.Assert res
      ##.block_data.Init device
      ##.text.Init device window
      core_data‚Üê(
          window:window
          device:device
          w:1280
          h:720
          dt:√∑60
          save:''
      )
     
      Game_loop core_data
     
      ##.text.Release device
      ##.block_data.Release device
      _‚Üê##.SDL_ReleaseWindowFromGPUDevice device window
      _‚Üê##.SDL_DestroyGPUDevice device
      _‚Üê##.SDL_DestroyWindow window
      ‚çù https://github.com/libsdl-org/SDL/issues/10081#issuecomment-2570813902
      _‚Üê##.SDL_PumpEvents
      _‚Üê##.SDL_Quit
    ‚àá

:EndNamespace
